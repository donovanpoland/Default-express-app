<%- include('../partials/head') %>
<%- include('../partials/header') %>
    <main>
        <h1><%= title %></h1>
        <form action="/register-user" method="POST" class="grid">
            <fieldset class="grid card">
            
                <label for="fname">First Name
                    <input 
                        type="text" 
                        name="fname" 
                        id="fname"
                        maxlength="100"
                        autocomplete="given-name"
                        required
                        value="<%= fname ?? '' %>"
                        >
                </label>

                <label for="lname">Last Name
                    <input 
                        type="text" 
                        name="lname" 
                        id="lname"
                        maxlength="100"
                        autocomplete="family-name"
                        required
                        value="<%= lname ?? '' %>"
                        >
                </label>

                <label for="email">Email
                    <input 
                    type="email"
                    id="email"
                    name="email"
                    autocomplete="email"
                    maxlength="255"
                    required
                    value="<%= email ?? '' %>"
                    >
                </label>

                <label for="password">
                    <span>Password <span id="caps-lock"> </span></span>
                    <span class="flex-row">
                        <input 
                        type="password"
                        id="password"
                        name="password"
                        minlength="8"
                        maxlength="72"
                        required
                        >
                        <button class="btn" type="button" id="toggle-password">Show password</button>
                    </span>
                </label>

                <label for="confirmPassword">
                    <span>Confirm Password</span>
                    <span class="flex-row">
                        <input 
                        type="password"
                        id="confirmPassword"
                        name="confirmPassword"
                        minlength="8"
                        maxlength="72"
                        required
                        >
                        <button class="btn" type="button" id="toggle-password">Show password</button>
                    </span>
                </label>
                
                <button class="btn" type="submit">Register</button>
            </fieldset>
        </form>
    </main>
<%- include('../partials/footer') %>
